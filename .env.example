# --- Core ---
NEXT_PUBLIC_APP_URL=http://localhost:3010
NEXT_PUBLIC_API_URL=

# --- MySQL ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=vscanmail

# --- Bank field encryption (AES-256-GCM + HMAC-SHA256) ---
# IMPORTANT:
# - Use 32-byte random keys.
# - Base64 is recommended. (Hex is also accepted by the runtime.)
# - Rotate by adding *_V2 keys later and bumping BANK_ENC_CURRENT_VERSION.
#
# Generate example keys (PowerShell):
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
#
BANK_ENC_CURRENT_VERSION=1
BANK_ENC_KEY_V1=REPLACE_WITH_32_BYTE_BASE64
BANK_ENC_HMAC_KEY_V1=REPLACE_WITH_32_BYTE_BASE64

