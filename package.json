{
  "name": "vscanmail",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev -p 3010",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next start -p 3010",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:repair": "npx tsx scripts/repair_missing_tables.ts",
    "db:normalize-collation": "npx tsx scripts/normalize-org-table-collation.ts",
    "stripe:listen": "stripe listen --forward-to localhost:3010/api/billing/stripe/webhook",
    "deploy:qa": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/deploy-qa.ps1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/client-textract": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@stripe/stripe-js": "^4.0.0",
    "bcryptjs": "^3.0.2",
    "dayjs": "^1.11.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.1.0",
    "mysql2": "^3.14.3",
    "nanoid": "^5.0.0",
    "next": "^15.5.15",
    "nodemailer": "^8.0.7",
    "openai": "^4.70.0",
    "otplib": "^12.0.0",
    "qrcode": "^1.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.0",
    "string-similarity-js": "^2.1.0",
    "stripe": "^17.0.0",
    "words-to-numbers": "^1.5.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.0",
    "@types/react": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "brace-expansion": "^1.1.13",
    "esbuild": "^0.27.4",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.10"
  }
}
